  "scripts": {
    "dev": "pi --extension ./src/extension.ts --model deepseek/deepseek-v4-flash",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
